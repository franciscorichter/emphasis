% Generated by hand
\name{eval_logf}
\alias{eval_logf}
\title{Evaluate log p(obs, z | theta) and log q(z | obs, theta) for augmented trees}
\usage{
eval_logf(
  pars,
  trees,
  model = as.integer(c(0, 0, 0)),
  link = 0L,
  rho = 1
)
}
\arguments{
\item{pars}{Numeric vector of 8 model parameters.}

\item{trees}{List of augmented-tree data frames, as returned by
\code{\link{augment_trees}}.}

\item{model}{Integer vector \code{c(use_N, use_P, use_E)}. Default
\code{c(0L, 0L, 0L)}.}

\item{link}{Link function: \code{0} = linear, \code{1} = exponential.
Default \code{0}.}

\item{rho}{Sampling fraction (0, 1]. Default \code{1} (complete sampling).}
}
\value{
A named list:
\describe{
  \item{\code{logf}}{Numeric vector of \eqn{\log p(\text{obs}, z_i \mid
    \theta)}, length = \code{length(trees)}.}
  \item{\code{logg}}{Numeric vector of \eqn{\log q(z_i \mid \text{obs},
    \theta)}, length = \code{length(trees)}.  This is the proposal
    density evaluated at the supplied \code{pars}, regardless of which
    parameters were used to simulate the trees.}
}
}
\description{
Given a list of augmented trees produced by \code{\link{augment_trees}}
and a parameter vector \eqn{\theta}, computes
\eqn{\log p(\text{obs}, z_i \mid \theta)} for each tree.

This function enables cross-IS evaluation: trees simulated from
\eqn{q(z \mid \text{obs}, \theta_i)} can be scored at a different
\eqn{\theta_j} without re-simulation.  IS aggregation is left to the
R layer via \code{.is_fhat(logf, logg)}.

Note: for N and P covariates, the model flag only affects augmentation
(the proposal); for scoring, the relevant parameters are already
encoded in \code{pars[2]} (beta_N) and \code{pars[3]} (beta_P).
The \code{model} flag is essential for the EP covariate (\code{model[3]
= 1}), which switches the rate functions from standard to EP-aware.
}
\seealso{
\code{\link{augment_trees}}, \code{\link{estimate_rates}}
}
\examples{
\dontrun{
brts  <- c(4, 2.5, 1.2, 0.6)
pars8 <- c(0.5, 0, 0, 0, 0.1, 0, 0, 0)
aug   <- augment_trees(brts, pars8, sample_size = 10L, maxN = 500L,
                       max_missing = 1000L, max_lambda = 100,
                       num_threads = 1L, model = c(0L,0L,0L), link = 0L)

# Score at same theta (identity check)
ef <- eval_logf(pars8, aug$trees, model = c(0L,0L,0L), link = 0L)
all.equal(ef$logf, aug$logf)   # TRUE

# Score at a different theta (cross-IS)
pars8_new <- c(0.6, 0, 0, 0, 0.15, 0, 0, 0)
ef_new <- eval_logf(pars8_new, aug$trees, model = c(0L,0L,0L), link = 0L)
fhat_cross <- emphasis:::.is_fhat(ef_new$logf, aug$logg)
}
}
