% Generated by hand
\name{augment_trees}
\alias{augment_trees}
\title{Draw augmented trees via importance sampling}
\usage{
augment_trees(
  brts,
  pars,
  sample_size,
  maxN,
  max_missing,
  max_lambda,
  num_threads,
  model = as.integer(c(0, 0, 0)),
  link = 0L
)
}
\arguments{
\item{brts}{Numeric vector of branching times (crown age first, sorted
decreasing).}

\item{pars}{Numeric vector of 8 model parameters
\code{c(beta_0, beta_N, beta_P, beta_E, gamma_0, gamma_N, gamma_P, gamma_E)}.}

\item{sample_size}{Number of valid augmented trees to collect.}

\item{maxN}{Maximum total augmentation attempts (including failures).}

\item{max_missing}{Maximum extinct lineages per augmented tree.}

\item{max_lambda}{Upper bound on the speciation rate (thinning bound).}

\item{num_threads}{Threads for parallel augmentation.}

\item{model}{Integer vector \code{c(use_N, use_P, use_E)}. Default
\code{c(0L, 0L, 0L)} (constant rate).}

\item{link}{Link function: \code{0} = linear (\code{max(0,eta)}),
\code{1} = exponential. Default \code{0}.}
}
\value{
A named list:
\describe{
  \item{\code{trees}}{List of augmented-tree data frames (\code{brts},
    \code{n}, \code{t_ext}, \code{pd}, \code{tip_start}, \code{id},
    \code{parent_id}).}
  \item{\code{logf}}{Numeric vector of
    \eqn{\log p(\text{obs}, z_i \mid \theta)} per tree.}
  \item{\code{logg}}{Numeric vector of
    \eqn{\log q(z_i \mid \text{obs}, \theta)} per tree.}
  \item{\code{rejected}}{Unhandled rejections.}
  \item{\code{rejected_overruns}}{Rejected: too many extinct lineages.}
  \item{\code{rejected_lambda}}{Rejected: lambda bound exceeded.}
  \item{\code{rejected_zero_weights}}{Rejected: zero IS weight.}
  \item{\code{time}}{Elapsed time (ms).}
}
}
\description{
Augments an observed extant tree (given by its branching times) with
stochastically drawn extinct lineages and returns the augmented trees
together with their log-likelihood (\code{logf}) and log proposal
probability (\code{logg}).

IS aggregation (\code{fhat}) is left to the R layer via
\code{.is_fhat(logf, logg)}, and re-scoring at a different parameter
point is handled by \code{\link{eval_logf}}.
}
\seealso{
\code{\link{eval_logf}}, \code{\link{estimate_rates}}
}
\examples{
\dontrun{
brts  <- c(4, 2.5, 1.2, 0.6)
pars8 <- c(0.5, 0, 0, 0, 0.1, 0, 0, 0)   # CR model, 8-param layout
aug   <- augment_trees(brts, pars8, sample_size = 10L, maxN = 500L,
                       max_missing = 1000L, max_lambda = 100,
                       num_threads = 1L, model = c(0L,0L,0L), link = 0L)
fhat  <- emphasis:::.is_fhat(aug$logf, aug$logg)
}
}
