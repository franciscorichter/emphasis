% Generated by hand
\name{augment_tree}
\alias{augment_tree}
\title{Augment an extant tree with simulated missing extinct lineages}
\usage{
augment_tree(
  tree,
  pars,
  sample_size = 1L,
  max_missing = 1e4,
  max_lambda = 500,
  soc = 2L,
  num_threads = 1L
)
}
\arguments{
\item{tree}{Observed extant tree. Accepts:
\itemize{
  \item the list returned by \code{\link{simulate_tree}} (uses \code{$brts}),
  \item a \code{phylo} object (extant tips only), or
  \item a numeric vector of branching times (crown age first,
    sorted decreasing).
}}

\item{pars}{Numeric parameter vector \code{c(mu, lambda0, betaN, betaP)}.}

\item{sample_size}{Number of independent augmented trees to draw.
  Default \code{1}.}

\item{max_missing}{Maximum number of missing (extinct) lineages added per
  augmented tree. Default \code{1e4}.}

\item{max_lambda}{Maximum per-lineage speciation rate during augmentation.
  Default \code{500}.}

\item{soc}{Stem (1) or crown (2) age condition. Default \code{2}.}

\item{num_threads}{Number of threads for parallel augmentation.
  Default \code{1}.}
}
\value{
A named list with elements:
\describe{
  \item{\code{trees}}{List of \code{sample_size} augmented trees, each a
    data frame with columns \code{brts} (time), \code{n} (richness),
    \code{t_ext} (extinction time; \code{1e11} = extant tip), \code{pd}.}
  \item{\code{weights}}{Log importance weights for each augmented tree.}
  \item{\code{fhat}}{Monte Carlo log-likelihood estimate.}
  \item{\code{logf}}{Log model likelihood of each augmented tree.}
  \item{\code{logg}}{Log sampling probability of each augmented tree.}
}
}
\description{
Given an observed extant phylogenetic tree, draws one or more augmented
copies in which the missing (extinct) lineages are filled in by stochastic
simulation under the model. This is the "conditional simulation" counterpart
of \code{\link{simulate_tree}}: instead of simulating a complete tree from
scratch, it conditions on the observed extant topology and adds back the
unobserved extinct branches.

This function performs the E-step of the MCEM inference algorithm. The
returned importance weights (\code{logf - logg}) and \code{fhat} can be
used directly for likelihood evaluation at the given parameters.
}
\seealso{
\code{\link{simulate_tree}} for full forward simulation;
\code{\link{estimate_rates}} which calls augmentation internally during
parameter inference.
}
\examples{
\dontrun{
set.seed(42)
sim <- simulate_tree(c(0.1, 0.5, -0.02, 0.01), max_t = 5)

# Draw 10 augmented copies of the extant tree
aug <- augment_tree(sim, pars = c(0.1, 0.5, -0.02, 0.01), sample_size = 10)
length(aug$trees)     # 10 augmented trees
aug$fhat              # Monte Carlo log-likelihood estimate
head(aug$trees[[1]])  # first augmented tree: columns brts, n, t_ext, pd

# Also accepts a phylo object directly
aug2 <- augment_tree(sim$tes, pars = c(0.1, 0.5, -0.02, 0.01), sample_size = 5)

# Or a numeric branching-time vector
aug3 <- augment_tree(sim$brts, pars = c(0.1, 0.5, -0.02, 0.01))
}
}
