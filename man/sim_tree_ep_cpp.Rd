% Generated by hand
\name{sim_tree_ep_cpp}
\alias{sim_tree_ep_cpp}
\title{Simulate a single phylogenetic tree under the EP model}
\usage{
sim_tree_ep_cpp(pars, max_t, max_lin = 1e+06, max_tries = 100, useDDD = TRUE)
}
\arguments{
\item{pars}{parameter vector with \code{c(mu, lambda0, betaN, betaP, betaE)}}

\item{max_t}{crown age}

\item{max_lin}{number of lineages past which non-extinction is assumed.}

\item{max_tries}{maximum number of tries to get a non-extinct tree.}

\item{useDDD}{whether to use DDD for tree conversion (default TRUE)}
}
\value{
list with: 1) tes - reconstructed tree, 2) tas - tree with extinct
lineages, 3) L = Ltable and 4) brts - branching times of the reconstructed
tree and 5) status of simulation, options 1) "extinct", 2) "too_large" or 3)
"done".
}
\description{
Fast C++ Gillespie direct simulation where each lineage's speciation rate
depends on its own pendant edge length \code{d_i = t - start_date_i} (time
since it last diverged). Per-lineage speciation rate:
\code{max(0, lambda0 + betaN*N + betaP*(P/N) + betaE*d_i)}.
Extinction rate \code{mu} is uniform across lineages.
}
\examples{
set.seed(123)
pars <- c(mu = 0.1, lambda0 = 0.5, betaN = -0.02, betaP = 0.01, betaE = 0.05)
tree_res <- try(sim_tree_ep_cpp(
  pars = pars,
  max_t = 5,
  max_lin = 1e4,
  max_tries = 5,
  useDDD = TRUE
))
if (!inherits(tree_res, "try-error") && !is.null(tree_res$tes)) {
  head(tree_res$tes$tip.label)
}
}
