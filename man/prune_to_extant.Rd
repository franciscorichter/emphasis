\name{prune_to_extant}
\alias{prune_to_extant}
\title{Prune extinct tips from a phylogenetic tree}
\usage{
prune_to_extant(phy, tol = 1e-08)
}
\arguments{
\item{phy}{A \code{phylo} object, possibly containing extinct lineages.}

\item{tol}{Tolerance for deciding whether a tip is at the present.
Default \code{1e-8}.}
}
\value{
A \code{phylo} object with only extant tips retained.
}
\description{
Drops tips that did not survive to the present (i.e. tips whose
root-to-tip distance is shorter than the maximum, within a small numerical
tolerance).
}
\examples{
\dontrun{
sim <- simulate_tree(c(0.1, 0.5, -0.02, 0.01), max_t = 5, model = "pd")
