% Generated by hand
\name{diagnose_mcem}
\alias{diagnose_mcem}
\title{Diagnostics for an MCEM fit}
\usage{
diagnose_mcem(x, plot = TRUE, lower_bound = NULL,
              upper_bound = NULL, true_pars = NULL)
}
\arguments{
\item{x}{An \code{emphasis_fit} object (from \code{\link{estimate_rates}}
  with \code{method = "mcem"}) or the raw list from the internal
  \code{.mcem_dynamic_fresh} function.}

\item{plot}{Logical; if \code{TRUE} (default), produce diagnostic plots.}

\item{lower_bound}{Optional numeric vector of lower parameter bounds.
  Dashed orange lines are drawn at these values in parameter trace panels.}

\item{upper_bound}{Optional numeric vector of upper parameter bounds.
  Dashed purple lines are drawn at these values in parameter trace panels.}

\item{true_pars}{Optional numeric vector of true parameter values
  (for simulation studies). Red dashed lines are drawn at these values.}
}
\value{
A list of class \code{"mcem_diagnostics"} (invisibly) with:
\describe{
  \item{\code{convergence}}{Data frame with per-iteration \code{fhat},
    \code{delta_max} (max relative parameter change), \code{num_trees},
    and \code{time}.}
  \item{\code{IS_quality}}{List with ESS, mean/sd of log-weights,
    and bootstrap variance at the final iteration.}
  \item{\code{final_IS}}{Raw IS components (\code{logf}, \code{logg},
    \code{lw}) from the final E-step.}
}
}
\description{
Computes convergence and importance-sampling quality diagnostics from
the output of \code{\link{estimate_rates}} with \code{method = "mcem"}.

Diagnostic plots include:
\describe{
  \item{Log-likelihood trace}{fhat vs. EM iteration, showing
    convergence of the sequence.}
  \item{Parameter traces}{Per-parameter estimates across iterations,
    with optional bound and true-value lines.}
  \item{Parameter stability}{Max relative parameter change (delta\_max)
    vs.\ iteration; convergence is declared when this falls below tol
    for patience consecutive iterations.}
  \item{IS weight histogram}{Distribution of IS log-weights at the
    final iteration, annotated with ESS.}
}
}
\seealso{
\code{\link{diagnose_cem}}, \code{\link{estimate_rates}}
}
\examples{
\dontrun{
sim <- simulate_tree(c(0.5, 0.1), max_t = 5, model = "cr")
fit <- estimate_rates(sim, method = "mcem", model = "cr",
  control = list(lower_bound = c(0, 0), upper_bound = c(2, 1)))
diagnose_mcem(fit, lower_bound = c(0, 0), upper_bound = c(2, 1))
}
}
